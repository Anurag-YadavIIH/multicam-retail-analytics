# ============================================================
# Smart Multi-Camera Retail Analytics System - Environment
# Copy to .env and adjust. NEVER commit .env
# ============================================================

# --- App ---
APP_ENV=development
APP_NAME=retail-vision-analytics
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=retail_analytics
POSTGRES_USER=retail
POSTGRES_PASSWORD=retail_dev_password
DATABASE_URL=postgresql+psycopg://retail:retail_dev_password@postgres:5432/retail_analytics

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Kafka (full profile only) ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_DETECTIONS_TOPIC=detections
KAFKA_EVENTS_TOPIC=events
KAFKA_ENABLED=false

# --- MinIO (object storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_FRAMES=frames
MINIO_BUCKET_REPORTS=reports
MINIO_SECURE=false

# --- Vision ---
YOLO_MODEL=yolo11n.pt          # nano model: runs on CPU / 8GB RAM. Use yolo11s/m on GPU
DEVICE=cpu                      # cpu | cuda:0
CONF_THRESHOLD=0.35
IOU_THRESHOLD=0.5
INFERENCE_FPS=5                 # frames per second sent to the detector (CPU friendly)
FRAME_WIDTH=960
ENABLE_FACE_BLUR=true
BATCH_SIZE=1

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=retail-analytics

# --- Alerts ---
SLACK_WEBHOOK_URL=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_TO=
ALERT_WEBHOOK_URL=

# --- Optional LLM keys (used by scripts/report_narrator.py) ---
OPENAI_API_KEY=
GROQ_API_KEY=

# --- Seed admin (created on first startup) ---
FIRST_ADMIN_EMAIL=admin@retail.local
FIRST_ADMIN_PASSWORD=admin12345
